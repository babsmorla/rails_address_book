<div class="max-w-2xl mx-auto mt-10">
  <%# Header Section %>
  <div class="mb-6 flex items-center justify-between">
    <h1 class="text-2xl font-bold text-gray-900">My Profile</h1>
    <%= link_to contacts_path, class: "flex items-center gap-2 text-sm font-medium text-indigo-600 hover:text-indigo-700 transition-colors" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
      </svg>
      View all contacts
    <% end %>
  </div>

  <%# Main Profile Card %>
  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="p-8">
      <div class="flex items-center gap-6 mb-8">
        <%# User Avatar Placeholder %>
        <div class="h-20 w-20 bg-indigo-100 rounded-full flex items-center justify-center text-indigo-600">
          <span class="text-3xl font-bold"><%= @user.username[0].upcase %></span>
        </div>
        <div>
          <h2 class="text-xl font-bold text-gray-800"><%= @user.username %></h2>
          <p class="text-gray-500 text-sm">Member since <%= @user.created_at.strftime("%B %Y") %></p>
        </div>
      </div>

      <%# Details Grid %>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 py-6 border-y border-gray-50">
        <div>
          <span class="block text-xs font-bold text-gray-400 uppercase tracking-wider mb-1">Username</span>
          <p class="text-gray-900 font-medium"><%= @user.username %></p>
        </div>
        <div>
          <span class="block text-xs font-bold text-gray-400 uppercase tracking-wider mb-1">Email Address</span>
          <p class="text-gray-900 font-medium"><%= @user.email %></p>
        </div>
      </div>

      <%# Action Buttons %>
      <div class="mt-8 flex flex-col sm:flex-row items-center gap-4">
        <%= link_to edit_user_path(@user), 
            class: "w-full sm:w-auto px-6 py-3 bg-indigo-600 text-white text-sm font-semibold rounded-xl shadow-md hover:bg-indigo-700 focus:ring-4 focus:ring-indigo-500/30 transition-all text-center" do %>
          Edit Profile
        <% end %>

        <%= link_to edit_password_path, 
            class: "w-full sm:w-auto px-6 py-3 bg-white text-gray-700 border border-gray-200 text-sm font-semibold rounded-xl hover:bg-gray-50 transition-all text-center flex items-center justify-center gap-2" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" />
          </svg>
          Change Password
        <% end %>
      </div>
    </div>
  </div>
</div>