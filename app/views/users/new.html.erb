<div class="bg-white max-w-md mx-auto mt-20 p-8 border border-gray-200 rounded-xl shadow-sm">
  <h1 class="text-2xl font-bold text-gray-900 mb-6 text-center">Sign Up</h1>

  <%= form_with model: @user, class: "flex flex-col gap-4" do |f| %>
    
    <div>
      <%= f.label :username, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :username, placeholder: "Username",
      required: true,
      class: "bg-place block w-full px-4 py-3 rounded-xl border-gray-300 shadow-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all placeholder:text-gray-400" %>
    </div>

    <div>
      <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.email_field :email, placeholder: "you@example.com", required: true,
      class: "bg-place block w-full px-4 py-3 rounded-xl border-gray-300 shadow-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all placeholder:text-gray-400" %>
    </div>
    
    <div>
      <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.password_field :password, placeholder: "••••••••", required: true, 
      class: "bg-place block w-full px-4 py-3 rounded-xl border-gray-300 shadow-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all placeholder:text-gray-400" %>
    </div>
    
    <div>
      <%= f.label :password_confirmation, "Confirm Password", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.password_field :password_confirmation, placeholder: "••••••••", required: true, 
      class: "bg-place block w-full px-4 py-3 rounded-xl border-gray-300 shadow-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all placeholder:text-gray-400" %>
    </div>

    <div class="mt-4">
      <%= f.submit "Create User", data: { 
        turbo_submits_with: "Signing up..." 
      }, class: "w-full flex justify-center py-2 px-4 border border-transparent rounded-lg shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-colors cursor-pointer" %>
    </div>
  <% end %>

  <div class="mt-6 text-center text-sm border-t pt-6 border-gray-100">
    <span class="text-gray-500">Already have an account?</span>
    <%= link_to 'Sign In', new_session_path, class: "text-indigo-600 font-medium hover:text-indigo-500 ml-1 transition-colors" %>
  </div>
</div>