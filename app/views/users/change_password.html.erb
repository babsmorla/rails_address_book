<div class="max-w-2xl mx-auto mt-10 bg-white p-8 rounded-2xl shadow-sm border border-gray-100">
  <h2 class="text-2xl font-bold text-gray-800 mb-6">Security Settings</h2>

  <%= form_with model: @user, url: update_password_path, method: :patch, class: "space-y-6" do |f| %>

    <%# Current Password - Single Column %>
    <div class="flex flex-col gap-1.5">
      <%= f.label :current_password, "Current Password", class: "text-sm font-semibold text-gray-700" %>
      <%= f.password_field :current_password, 
          required: true,
          placeholder: "••••••••", 
          class: "block w-full px-4 py-3 rounded-xl border-gray-300 shadow-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all placeholder:text-gray-400 #{'border-red-500 bg-red-50' if @user.errors[:current_password].any?}" %>
      
      <% if @user.errors[:current_password].any? %>
        <p class="text-sm text-red-600 mt-1"><%= @user.errors[:current_password].first %></p>
      <% end %>
    </div>

    <div class="border-t border-gray-100 pt-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <%# New Password %>
        <div class="flex flex-col gap-1.5">
          <%= f.label :password, "New Password", class: "text-sm font-semibold text-gray-700" %>
          <%= f.password_field :password, 
              required: true,
              placeholder: "Minimum 6 characters", 
              class: "block w-full px-4 py-3 rounded-xl border-gray-300 shadow-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all placeholder:text-gray-400 #{'border-red-500 bg-red-50' if @user.errors[:password].any?}" %>
          
          <% if @user.errors[:password].any? %>
            <p class="text-sm text-red-600 mt-1"><%= @user.errors[:password].first %></p>
          <% end %>
        </div>

        <%# Password Confirmation %>
        <div class="flex flex-col gap-1.5">
          <%= f.label :password_confirmation, "Confirm New Password", class: "text-sm font-semibold text-gray-700" %>
          <%= f.password_field :password_confirmation, 
              required: true,
              placeholder: "Repeat new password", 
              class: "block w-full px-4 py-3 rounded-xl border-gray-300 shadow-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all placeholder:text-gray-400" %>
        </div>
      </div>
    </div>

    <%# Action Buttons %>
    <div class="pt-4 flex items-center justify-end gap-3 border-t border-gray-100">
      <%= link_to 'Cancel', user_path(@user), class: "px-6 py-2.5 text-sm font-medium text-gray-700 hover:bg-gray-50 rounded-xl transition-colors" %>
      <%= f.submit "Update Password", 
          class: "px-6 py-2.5 bg-indigo-600 text-white text-sm font-semibold rounded-xl shadow-md hover:bg-indigo-700 focus:ring-4 focus:ring-indigo-500/30 transition-all cursor-pointer" %>
    </div>

  <% end %>
</div>