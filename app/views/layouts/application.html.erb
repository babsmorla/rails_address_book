<!DOCTYPE html>
<html>
 <head>
    <title><%= content_for(:title) || "My Addressbook" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>
    <%= stylesheet_link_tag "tailwind", "inter-font", "data-turbo-track": "reload" %>

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <link rel="icon" href="/icon.png" type="image/png">

  </head>

  <body class="header-layout flex flex-col mt-20">



    

<nav class="bg-white/50 backdrop-blur-md fixed w-full z-20 top-0 start-0 border-b border-default">
  <div class="max-w-screen-xl flex flex-wrap items-center justify-between mx-auto p-4">
    <a href="https://flowbite.com/" class="flex items-center space-x-3 rtl:space-x-reverse">
        <img src="https://www.svgrepo.com/show/520495/book.svg" class="h-7" alt="Flowbite Logo">
        <span class="self-center text-xl text-heading font-semibold whitespace-nowrap">AddressBook</span>
    </a>
    
    <div class="items-center justify-between hidden w-full md:flex md:w-auto md:order-1" id="navbar-sticky">
      <ul class="flex flex-col p-4 md:p-0 mt-4 font-medium border border-default rounded-base bg-neutral-secondary-soft md:space-x-8 rtl:space-x-reverse md:flex-row md:mt-0 md:border-0 md:bg-neutral-primary">
       <div class="flex md:order-2 space-x-3 md:space-x-0 rtl:space-x-reverse">
        <% if current_user %>
          <div class="hidden md:flex items-center space-x-4 mr-4">
            <span class="text-sm font-medium text-gray-500">Welcome, <span class="text-gray-900"><%= current_user.username %></span></span>
          </div>
          <%= link_to 'Logout', session_path(current_user), 
              data: { turbo_method: :delete }, 
              class: "text-white bg-red-600 hover:bg-red-700 focus:ring-4 focus:outline-none focus:ring-red-300 font-medium rounded-lg text-sm px-4 py-2 text-center transition-all shadow-sm" %>
        <% else %>
          <%= link_to 'Get Started', new_session_path, 
              class: "text-white bg-green-600 hover:bg-green-700 focus:ring-4 focus:outline-none hover:text-white focus:ring-indigo-300 font-medium rounded-lg text-sm px-4 py-2 text-center transition-all shadow-md" %>
        <% end %>

            </div>
      </ul>
    </div>
  </div>
</nav>

    
  <% if notice.present? %>
  <div popover="manual" class="flash" data-controller="flash">
    <div class="flash__content">
      <%= notice %>
    </div>
  </div>
<% end %>
  

    <main id="main">
      <div class="container  w-full md:w-auto h-screen">
        <%= yield %>
      </div>
    </main>
  </body>
</html>
