<!DOCTYPE html>
<html>
 <head>
  <title><%= content_for(:title) || "My Addressbook" %></title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= yield :head %>

  <%# Combine your primary styles here. Rails will handle the preloading correctly. %>
  <%= stylesheet_link_tag :application, "tailwind", "inter-font", "application", "data-turbo-track": "reload" %>
  
  <%= javascript_importmap_tags %>

  <link rel="icon" href="/icon.png" type="image/png">
</head>

  <body class="header-layout flex flex-col mt-20 min-h-screen bg-gray-200">



    

<nav data-controller="navbar" class="bg-white/80 backdrop-blur-md fixed w-full z-20 top-0 start-0 border-b border-default">
  <div class="max-w-screen-xl flex flex-wrap items-center justify-between mx-auto p-4">
    <a href="/" class="flex items-center space-x-3 rtl:space-x-reverse">
        <img src="https://www.svgrepo.com/show/520495/book.svg" class="h-7" alt="Logo">
        <span class="self-center text-xl text-heading font-semibold whitespace-nowrap">AddressBook</span>
    </a>

    <button data-action="click->navbar#toggle" type="button" class="inline-flex items-center p-2 w-10 h-10 justify-center text-sm text-gray-500 rounded-lg md:hidden hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-gray-200" aria-controls="navbar-sticky" aria-expanded="false">
      <span class="sr-only">Open main menu</span>
      <svg class="w-5 h-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 17 14">
        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 1h15M1 7h15M1 13h15"/>
      </svg>
    </button>
    
    <div data-navbar-target="menu" class="items-center justify-between hidden w-full md:flex md:w-auto md:order-1" id="navbar-sticky">
      <ul class="flex flex-col p-4 md:p-0 mt-4 font-medium border border-default rounded-base bg-neutral-secondary-soft md:space-x-8 rtl:space-x-reverse md:flex-row md:mt-0 md:border-0 md:bg-neutral-primary">
        <div class="flex flex-col md:flex-row md:order-2 space-y-3 md:space-y-0 md:space-x-3 rtl:space-x-reverse">
          <% if current_user %>
            <div class="hidden md:flex items-center space-x-4 mr-4">
              <span class="text-sm font-medium text-gray-500">Welcome, <span class="text-gray-900"><%= current_user.username %></span></span>
            </div>
            
            <div class="md:hidden text-sm font-medium text-gray-500 border-b border-default pb-2">
              Welcome, <%= current_user.username %>
            </div>

            <div class="flex flex-col md:flex-row space-y-2 md:space-y-0 md:space-x-2">
              <%= link_to 'View Profile', user_path(current_user), 
                  class: "text-white bg-indigo-600 hover:bg-indigo-700 focus:ring-4 focus:outline-none focus:ring-indigo-300 font-medium rounded-lg text-sm px-4 py-2 text-center transition-all shadow-sm hover:text-white" %>

              <%= link_to 'Logout', session_path(current_user), 
                  data: { turbo_method: :delete }, 
                  class: "text-white bg-red-600 hover:bg-red-700 focus:ring-4 focus:outline-none focus:ring-red-300 font-medium rounded-lg text-sm px-4 py-2 text-center transition-all hover:text-white shadow-sm" %>
            </div>
          <% else %>
            <%= link_to 'Get Started', new_session_path, 
                class: "text-white bg-green-600 hover:bg-green-700 focus:ring-4 focus:outline-none hover:text-white focus:ring-indigo-300 font-medium rounded-lg text-sm px-4 py-2 text-center transition-all shadow-md" %>
          <% end %>
        </div>
      </ul>
    </div>
  </div>
</nav>

    
  <% if notice.present? %>
  <div popover="manual" class="flash" data-controller="flash">
    <div class="flash__content">
      <%= notice %>
    </div>
  </div>
<% end %>
  

    <main id="main">
      <div class=" mx-auto  h-screen ">
    <%= yield %>
    </div>
    </main>
  </body>
</html>
