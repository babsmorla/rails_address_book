<div class="bg-white max-w-md mx-auto mt-20 p-8 border border-gray-200 rounded-xl shadow-sm">
  <h1 class="text-2xl font-bold text-gray-900 mb-6 text-center">Sign In</h1>

  <%= form_with url: sessions_path, method: :post do |f| %>
    <div class="space-y-4">
      <div>
        <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.email_field :email, 
            placeholder: "you@example.com", 
            required: true,
            class: "bg-place block w-full px-4 py-3 rounded-xl border-gray-300 shadow-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all placeholder:text-gray-400" %>
      </div>
    
      <div>
        <div class="flex justify-between items-center mb-1">
          <%= f.label :password, class: "block text-sm font-medium text-gray-700" %>
          
          <%# Updated helper name to new_password_reset_path %>
          <%= link_to "Forgot password?", new_password_reset_path, 
              class: "text-xs font-medium text-indigo-600 hover:text-indigo-500 transition-colors" %>
        </div>

        <%= f.password_field :password, placeholder: "••••••••", 
            required: true,
            class: "bg-place block w-full px-4 py-3 rounded-xl border-gray-300 shadow-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all placeholder:text-gray-400" %>
      </div>
    </div>

    <div class="mt-6">
      <%= f.submit "Login", data: { 
        turbo_submits_with: "Verifying..." 
      }, class: "w-full flex justify-center py-3 px-4 border border-transparent rounded-xl shadow-md text-sm font-semibold text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-all cursor-pointer" %>
    </div>
  <% end %>

  <div class="mt-6 text-center text-sm border-t pt-6 border-gray-100">
    <span class="text-gray-500">Don't have an account?</span>
    <%= link_to 'Sign Up', new_user_path, class: "text-indigo-600 font-medium hover:text-indigo-500 ml-1 transition-colors" %>
  </div>
</div>