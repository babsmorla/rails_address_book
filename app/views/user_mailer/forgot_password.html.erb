<div style="margin: 0; padding: 0; background: linear-gradient(135deg, #eef2ff, #f8fafc); font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;">
  <table border="0" cellpadding="0" cellspacing="0" width="100%">
    <tr>
      <td style="padding: 50px 20px;">
        <table align="center" border="0" cellpadding="0" cellspacing="0" width="520" style="background-color: #ffffff; border-radius: 14px; overflow: hidden; box-shadow: 0 10px 30px rgba(79, 70, 229, 0.08); border: 1px solid #e5e7eb;">
          
          <!-- Header -->
          <tr>
            <td style="padding: 35px 40px 15px; text-align: center; background-color: #f5f7ff;">
              <h1 style="color: #4338ca; margin: 0; font-size: 26px; font-weight: 700; letter-spacing: -0.5px;">
                MyAddressbook
              </h1>
            </td>
          </tr>

          <!-- Content -->
          <tr>
            <td style="padding: 30px 40px;">
              <h2 style="color: #111827; font-size: 20px; font-weight: 600; margin: 0 0 16px;">
                Password Reset Request
              </h2>
              <p style="color: #4b5563; font-size: 15px; line-height: 25px; margin: 0;">
                Hello <%= @user.username.presence || "there" %>, <br><br>
                We received a request to reset the password for your account. No changes have been made yet.
                Click the button below to reset your password securely.
              </p>
            </td>
          </tr>

          <!-- Button -->
          <tr>
            <td style="padding: 0 40px 30px; text-align: center;">
              <a href="<%= @url %>" style="display: inline-block; background: linear-gradient(135deg, #4f46e5, #4338ca); color: #ffffff; padding: 14px 32px; border-radius: 8px; text-decoration: none; font-weight: 600; font-size: 15px; box-shadow: 0 6px 14px rgba(79, 70, 229, 0.25);">
                Reset My Password
              </a>
            </td>
          </tr>

          <!-- Info -->
          <tr>
            <td style="padding: 0 40px 30px;">
              <p style="color: #6b7280; font-size: 13px; line-height: 22px; margin: 0; text-align: center; border-top: 1px solid #f3f4f6; padding-top: 20px;">
                This link will expire in <strong>1 hour</strong>.<br>
                If you did not request this, you can safely ignore this email.
              </p>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="padding: 20px 40px; background-color: #f9fafb; text-align: center;">
              <p style="color: #9ca3af; font-size: 12px; line-height: 20px; margin: 0;">
                Trouble with the button? Copy and paste this link:<br>
                <a href="<%= @url %>" style="color: #4338ca; text-decoration: underline;"><%= @url %></a>
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</div>